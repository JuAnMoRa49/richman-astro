---
import { NAV_LINKS } from "../consts";
import { EXTRA_LINKS } from "../consts";
import { COMPANY_INFO } from "../consts";
const today = new Date();
---

<footer class="bg-white text-primary">
  <div class="flex flex-col general-padding py-8 gap-8">
    <div class="flex flex-col md:flex-row md:justify-between gap-8">
      <section class="flex gap-4 md:flex-2">
        <img src="/logo.svg" alt="Richman Componentes Logo" class="size-24" />
        <div>
          <p class="uppercase text-3xl font-bold">
            Richman <span class="block">Componentes</span>
          </p>
          <p class="opacity-40">{COMPANY_INFO.address}</p>
        </div>
      </section>
      <nav class="flex justify-between md:flex-1">
        <ul class="flex flex-col gap-2">
          <p class="font-bold opacity-40 uppercase">Navegacion</p>
          {
            NAV_LINKS.map((link) => (
              <li>
                <a href={link.href} class="hover:text-primary font-semibold">
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
        <ul class="flex flex-col gap-2 text-right">
          <p class="font-bold opacity-40 uppercase">Soporte</p>
          {
            EXTRA_LINKS.map((link) => (
              <li>
                <a href={link.href} class="hover:text-primary font-semibold">
                  {link.name}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
    <form class="flex flex-col gap-4">
      <h2
        class="scroll-m-20 text-2xl md:text-3xl xl:text-4xl font-semibold tracking-tight text-primary"
      >
        Contactanos
      </h2>
      <div class="md:flex justify-between gap-4">
        <div class="flex flex-col gap-1 md:w-full">
          <label for="name" class="text-sm font-medium text-primary">
            Nombre
          </label>
          <input
            id="name"
            name="name"
            type="text"
            placeholder="Ingresa tu nombre"
            required
            class="px-3 py-2 border border-primary/40 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary/80"
          />
        </div>
        <div class="flex flex-col gap-1 md:w-full">
          <label for="email" class="text-sm font-medium text-primary">
            Correo Electrónico
          </label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder="example@email.com"
            required
            class="px-3 py-2 border border-primary/40 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary/80"
          />
        </div>
        <div class="flex flex-col gap-1 md:w-full">
          <label for="phone" class="text-sm font-medium text-primary">
            Teléfono
          </label>
          <input
            id="phone"
            name="phone"
            type="number"
            placeholder="442 123 4567"
            required
            class="px-3 py-2 border border-primary/40 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary/80"
          />
        </div>
      </div>
      <div class="md:flex justify-between gap-4">
        <div class="flex flex-col gap-1 md:w-full">
          <label for="reason" class="text-sm font-medium text-primary">
            Motivo de contacto
          </label>
          <input
            id="reason"
            name="reason"
            type="text"
            placeholder="Motivo de contacto"
            required
            class="px-3 py-2 border border-primary/40 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary/80"
          />
        </div>
        <div class="flex flex-col gap-1 md:w-full">
          <label for="comments" class="text-sm font-medium text-primary">
            Comentarios extras
          </label>
          <input
            id="comments"
            name="comments"
            type="text"
            placeholder="Comentarios extras"
            class="px-3 py-2 border border-primary/40 rounded-lg focus:outline-none focus:ring-1 focus:ring-primary/80"
          />
        </div>
      </div>
      <button
        type="submit"
        class="px-3 py-2 border bg-primary text-white rounded-lg">Enviar</button
      >
    </form>
    <p class="text-center text-4xl font-bold">
      Tenemos cuerda para lo más especial
    </p>
  </div>
  <div>
    <p class="text-center bg-primary text-white">
      &copy; {new Date().getFullYear()} Richman Componentes. Todos los derechos reservados.
    </p>
    <p>
      Crado por <a
        href="https://www.morartstrudio.com"
        class="text-primary hover:underline">Morart</a
      >
    </p>
  </div>
</footer>
