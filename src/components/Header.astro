---
import "../styles/global.css";
import { NAV_LINKS } from "../consts.ts";
import { ArrowRightIcon, Menu } from "@lucide/astro";
---

<header class="bg-white text-primary font-semibold">
  <div class="general-padding flex justify-between items-center h-16">
    <div class="flex items-center gap-4 xl:flex-1">
      <img src="/logo.svg" alt="Richman Componentes Logo" class="size-8" />
      <p class="uppercase text-xl font-bold">Richman Componentes</p>
    </div>

    <button class="md:hidden"><Menu /></button>

    <nav class="hidden md:flex xl:flex-1 justify-center">
      <ul class="flex justify-center space-x-4">
        {
          NAV_LINKS.map((link) => (
            <li key={link.key}>
              <a
                href={link.href}
                class="relative after:absolute after:-bottom-1 after:left-0 after:h-[2px] after:w-0 after:bg-primary after:transition-all after:duration-300 hover:after:w-full"
              >
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="hidden lg:flex justify-end xl:flex-1">
      <button
        class="flex self-end items-center text-white bg-primary rounded-md px-3 py-1.5"
        id="contact-button"
      >
        <p>Contacto</p>
        <ArrowRightIcon class="inline-block w-4 h-4 ml-1" />
      </button>
    </div>
  </div>
</header>
