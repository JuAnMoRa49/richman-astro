---
interface CardItem {
  title: string;
  description: string;
  badge?: string;
  image?: string;
}

interface Props {
  title: string;
  subtitle?: string;
  cards: CardItem[];
}

const { title, subtitle, cards } = Astro.props;

import { Image } from "astro:assets";
---

<section class="relative bg-beige py-20">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row gap-16">
    <div class="w-full md:w-1/3">
      <div class="sticky top-24">
        {
          subtitle && (
            <p class="text-primary font-bold tracking-[0.2em] uppercase text-[10px] mb-4">
              {subtitle}
            </p>
          )
        }
        <h2
          class="text-4xl md:text-5xl font-bold text-chocolate-vibrant leading-tight mb-8"
        >
          {title}
        </h2>
        <slot name="left-content" />
      </div>
    </div>

    <div class="w-full md:w-2/3 flex flex-col gap-6">
      {
        cards.map((card, index) => (
          <div
            class="sticky"
            style={`top: ${100 + index * 40}px; z-index: ${index + 1};`}
          >
            <div class="bg-white rounded-[2rem] p-8 shadow-xl border border-white/10 min-h-[400px] flex flex-col">
              {card.badge && (
                <span class="inline-block px-3 py-1 mb-4 text-xs font-bold rounded-full bg-primary/10 text-primary w-fit">
                  {card.badge}
                </span>
              )}
              <h3 class="text-2xl font-bold mb-4">{card.title}</h3>
              <p class="text-gray-600 flex-grow">{card.description}</p>
              {card.image && (
                <Image
                  src={card.image}
                  alt={card.title}
                  class="mt-8 rounded-xl w-full h-48 object-cover"
                />
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
