---
import { Image } from "astro:assets";

const { title, subtitle, leftIcon, rightIcon, theme = "light" } = Astro.props;
const isDark = theme === "dark";
const iconClass = `absolute opacity-10 w-72 h-72 pointer-events-none ${
  isDark ? "brightness-0 invert" : "brightness-0"
}`;
---

<section
  class={`relative overflow-hidden ${isDark ? "text-white bg-primary" : "text-primary bg-white"}`}
>
  <div class="general-padding py-32 text-center relative z-10">
    <h2
      class={`scroll-m-20 text-3xl md:text-4xl xl:text-5xl font-semibold xl:w-3/4 mx-auto mb-4 ${
        isDark ? "text-white" : "text-primary"
      }`}
    >
      {title}
    </h2>
    <p
      class={`text-lg w-1/2 mx-auto ${isDark ? "text-white/70" : "text-chocolate"}`}
    >
      {subtitle}
    </p>
  </div>

  {
    leftIcon && (
      <Image
        src={leftIcon}
        width={24}
        height={24}
        alt=""
        class={`icon-spin -left-24 -bottom-24 lg:-bottom-24 ${iconClass}`}
        loading="eager"
      />
    )
  }

  {
    rightIcon && (
      <Image
        src={rightIcon}
        width={24}
        height={24}
        alt=""
        class={`icon-spin-reverse -right-24 -top-24 lg:-top-24 ${iconClass}`}
        loading="eager"
      />
    )
  }
</section>

<style>
  .icon-spin {
    animation: spinSlow 20s linear infinite;
  }

  .icon-spin-reverse {
    animation: spinSlowReverse 25s linear infinite;
  }

  @keyframes spinSlow {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes spinSlowReverse {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }
</style>
