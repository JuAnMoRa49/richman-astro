---
const {
  title,
  description,
  restrict,
  limit = 4,
  superlimit = false,
} = Astro.props;
import { getCollection } from "astro:content";
import BlogCard from "./BlogCard.astro";

const allPosts = await getCollection("blog");

// Filtrar según restrict
const posts = restrict
  ? allPosts.filter((p) => p.data[restrict] === true)
  : allPosts;
---

<section class="py-8 bg-white text-primary">
  <div class="general-padding">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-bold text-primary">
        {title}
      </h2>
      <p class="font-serif text-primary">
        {description}
      </p>
    </div>

    <ul class="flex flex-col md:grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        posts.map((post, index) => (
          <li class="post-item" data-index={index}>
            <BlogCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              image={post.data.image}
            />
          </li>
        ))
      }
    </ul>

    {
      !superlimit && posts.length > limit && (
        <div class="text-center mt-4">
          <button
            id="show-more-button"
            class="px-4 py-2 rounded bg-primary text-white"
          >
            Mostrar más
          </button>
        </div>
      )
    }
  </div>
</section>

<script define:vars={{ limit }}>
  const items = document.querySelectorAll(".post-item");
  const btn = document.getElementById("show-more-button");
  let visible = limit;

  items.forEach((item, i) => {
    if (i >= limit) item.style.display = "none";
  });

  btn?.addEventListener("click", () => {
    visible += limit;
    items.forEach((item, i) => {
      if (i < visible) item.style.display = "";
    });
    if (visible >= items.length) btn.style.display = "none";
  });
</script>
