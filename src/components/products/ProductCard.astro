---
const { title, description, category, subcategory, image, href } = Astro.props;
import { Image } from "astro:assets";
---

<a
  href={href}
  class="group flex flex-row sm:flex-col border rounded-xl overflow-hidden hover:border-primary/20 transition-all duration-300"
>
  <div class="flex md:flex-col p-1 gap-2">
    <div
      class="relative w-32 shrink-0 sm:w-full sm:aspect-square bg-beige flex items-center justify-center overflow-hidden"
    >
      <Image
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>

    <div class="flex flex-col justify-between py-4 pr-2">
      <p class="uppercase text-xs text-primary/40 font-semibold line-clamp-1">
        {subcategory}
      </p>
      <h3 class="uppercase font-bold line-clamp-1">{title}</h3>
      <p class="card-description line-clamp-2 text-xs">{description}</p>
    </div>
  </div>
</a>
