---
const { title, description, category, subcategory, image, href, theme } =
  Astro.props;
import { Image } from "astro:assets";
---

<a
  href={href}
  class={` group flex flex-row sm:flex-col border rounded-xl overflow-hidden ${theme === "dark" ? " hover:border-white" : " hover:border-primary"} border-gray-400/40 transition-all duration-300`}
>
  <div class="flex md:flex-col bg-gray-400/20">
    <div
      class="relative w-32 shrink-0 sm:w-full sm:aspect-square overflow-hidden"
    >
      <Image
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    </div>

    <div class="flex flex-col justify-around py-4 p-2">
      <p
        class={`uppercase text-xs font-semibold line-clamp-1 mb-2 ${theme === "dark" ? "text-white/40" : "text-primary"}`}
      >
        {subcategory}
      </p>
      <h3
        class={`uppercase font-bold line-clamp-1 ${theme === "dark" ? "text-white" : "text-primary"}`}
      >
        {title}
      </h3>
      <p
        class={`card-description line-clamp-2 text-xs ${theme === "dark" ? "text-white" : "text-primary"}`}
      >
        {description}
      </p>
    </div>
  </div>
</a>
