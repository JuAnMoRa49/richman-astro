---
const {
  title,
  description,
  theme,
  restrict,
  limit = 4,
  superlimit = false,
} = Astro.props;
import { getCollection } from "astro:content";
import ProductCard from "./ProductCard.astro";

const allProducts = await getCollection("catalog");

// Filtrar según restrict
const products = restrict
  ? allProducts.filter((p) => p.data[restrict] === true)
  : allProducts;
---

<section
  class={`py-8 ${theme === "dark" ? "bg-primary text-white" : "bg-white text-primary"}`}
>
  <div class="general-padding">
    <div class="text-center mb-8">
      <h2
        class={`text-3xl font-bold ${theme === "dark" ? "text-white" : "text-primary"}`}
      >
        {title}
      </h2>
      <p
        class={`font-serif ${theme === "dark" ? "text-white" : "text-primary"}`}
      >
        {description}
      </p>
    </div>

    <ul class="flex flex-col md:grid md:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        products.map((product, index) => (
          <li class="product-item" data-index={index}>
            <ProductCard
              href={`/catalogo/${product.id}`}
              title={product.data.title}
              description={product.data.description}
              category={product.data.category}
              image={product.data.image}
              theme={theme}
            />
          </li>
        ))
      }
    </ul>

    {
      !superlimit && products.length > limit && (
        <div class="text-center mt-4">
          <button
            id="show-more-button"
            class={`px-4 py-2 rounded ${theme === "dark" ? "bg-white text-primary" : "bg-primary text-white"}`}
          >
            Mostrar más
          </button>
        </div>
      )
    }
  </div>
</section>

<script define:vars={{ limit }}>
  const items = document.querySelectorAll(".product-item");
  const btn = document.getElementById("show-more-button");
  let visible = limit;

  items.forEach((item, i) => {
    if (i >= limit) item.style.display = "none";
  });

  btn?.addEventListener("click", () => {
    visible += limit;
    items.forEach((item, i) => {
      if (i < visible) item.style.display = "";
    });
    if (visible >= items.length) btn.style.display = "none";
  });
</script>
