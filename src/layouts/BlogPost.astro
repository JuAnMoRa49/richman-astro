---
import BlogDisplay from "../components/blog/BlogDisplay.astro";
import GeneralLayout from "./GeneralLayout.astro";
import { Image } from "astro:assets";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  category?: string;
}

const { title, description, image, category } = Astro.props;
---

<GeneralLayout title={title} description={description} image={image}>
  <!-- Hero -->
  <section class="relative w-full">
    <Image
      src={image}
      alt={title}
      class="w-full h-[420px] md:h-[520px] object-cover"
    />
    <div
      class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"
    >
    </div>
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
      {
        category && (
          <span class="inline-block text-xs font-semibold uppercase tracking-widest text-white/80 border border-white/30 bg-white/10 rounded-full px-3 py-1 mb-4">
            {category}
          </span>
        )
      }
      <h1
        class="text-3xl md:text-5xl xl:text-6xl font-bold text-white leading-tight mb-4 max-w-3xl"
      >
        {title}
      </h1>
      <p
        class="text-base md:text-xl text-white/75 font-serif max-w-2xl leading-relaxed"
      >
        {description}
      </p>
    </div>
  </section>

  <!-- Contenido del post -->
  <section class="py-12 bg-white text-primary">
    <div class="general-padding">
      <slot />
    </div>
  </section>

  <!-- Artículos relacionados -->
  <div class="border-t">
    <BlogDisplay
      title="Artículos relacionados"
      description="Explora más contenido relacionado con este tema."
      theme="light"
      limit={3}
      superlimit={true}
    />
  </div>
</GeneralLayout>
