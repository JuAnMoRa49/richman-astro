---
import GeneralLayout from "../../layouts/GeneralLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import BlogDisplay from "../../components/blog/BlogDisplay.astro";
import TextWithIcons from "../../components/TextWithIcons.astro";
---

<GeneralLayout>
  <HeroSection
    title="Somos parte de la cadena de suministro global"
    description="Participamos en diferentes eventos y ferias comerciales alrededor del mundo para conectar con clientes y socios potenciales."
    video="/heros/blog-hero.mp4"
    ctaText="Conoce nuestros eventos"
    ctaLink="#eventos"
  />
  <BlogDisplay
    id="eventos"
    title="Nuestros Eventos"
    description="Participamos en diferentes eventos y ferias comerciales alrededor del mundo para conectar con clientes y socios potenciales."
    theme="light"
    limit={4}
    loading="eager"
  />
  <TextWithIcons
    title="Sé parte de la comunidad de excelencia industrial"
    leftIcon="/icons/tuerca.svg"
    rightIcon="/icons/engranaje.svg"
    theme="dark"
  />
</GeneralLayout>
