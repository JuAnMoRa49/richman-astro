---
import GeneralLayout from "../../layouts/GeneralLayout.astro";
import HeroSection from "../../components/HeroSection.astro";
import ProductsDisplay from "../../components/products/ProductsDisplay.astro";
---

<GeneralLayout>
  <HeroSection
    title="Tenemos lo que necesitas"
    description="En nuestro catálogo encontrarás una amplia variedad de productos y servicios diseñados para satisfacer tus necesidades. Desde soluciones innovadoras hasta opciones personalizadas, estamos comprometidos a ofrecerte lo mejor en calidad y valor."
    video="/heros/catalog-hero.mp4"
  />
  <ProductsDisplay
    id="destacados"
    title="Productos Estrella"
    description="Nuestro producto más destacado, con características excepcionales y una demanda creciente en el mercado."
    restrict="highlight"
    theme="dark"
    limit={4}
    loading="eager"
  />
  <ProductsDisplay
    id="servicios"
    title="Nuestros Servicios"
    description="Además de nuestros productos, ofrecemos una gama de servicios complementarios para satisfacer las necesidades de nuestros clientes."
    restrict="service"
    theme="light"
    limit={4}
  />
  <ProductsDisplay
    title="Nuestros Productos"
    description="Nuestras soluciones con mayor demanda, certificadas bajo los más estrictos estándares de calidad industrial."
    restrict="product"
    theme="dark"
    limit={8}
  />
</GeneralLayout>
